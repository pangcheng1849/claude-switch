{
  "name": "@cheng-pang/claude-switch",
  "version": "0.2.0",
  "description": "Interactive CLI tool to switch Claude Code Model API providers",
  "type": "module",
  "bin": {
    "claude-switch": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "provider",
    "switch"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pangcheng1849/claude-switch.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
